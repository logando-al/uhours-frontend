# UHours Frontend — Environment Variables
# Copy this file to .env.local and fill in the values

# Backend API base URL
NUXT_PUBLIC_API_BASE_URL=https://uhours-api.ltechnosoft.com/api/v1

# Cloudflare Turnstile site key (public — from Cloudflare dashboard)
NUXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# App name (optional)
NUXT_PUBLIC_APP_NAME=UHours
